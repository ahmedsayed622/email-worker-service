create or replace procedure CMP_CLIENTS_PRO_DOB as 
v_rowcount NUMBER;
begin

INSERT INTO CMP_CLIENTS_TBL_CTRL_DOB 
VALUES ( TO_NUMBER ( TO_CHAR(SYSDATE,'YYYYMMDD') )) ;


INSERT INTO CMP_CLIENTS_TBL_DOB (
PROFILE_ID, CUSTOMER_NAME_EN, CUSTOMER_NAME_AR, NIN, 
C_ACCOUNT, MOBILE_1, MOBILE_2, CLIENT_SUSPEND, NOTES, DOB, DATE_OF_BIRTH, FLAG
)

select distinct A.PROFILE_ID, A.CUSTOMER_NAME_EN, A.CUSTOMER_NAME_AR , B.NIN , B.C_ACCOUNT,A.MOBILE_1,A.MOBILE_2,case when ALL_TO_DATE > TO_NUMBER(TO_CHAR(SYSDATE,'YYYYMMDD')) then 'Yes' else 'No' end as client_SUSPEND, C.NOTES, A.DOB,
EDATA_CAST_DATETIME ( A.DOB , 'D,/,M,/,Y') as date_of_birth ,1
from T_PROFILE_INFO_SETTING A
inner join T_INVESTMENT_ACCOUNT_PROFILE B ON A.PROFILE_ID = B.PROFILE_ID 
left join BO_CLIENT_SUSPEND c on A.PROFILE_ID = C.PROFILE_ID
where A.PROFILE_ID = B.PROFILE_ID 
and substr(A.DOB,5,4) between TO_NUMBER(TO_CHAR(SYSDATE,'MM') || '01')
                             and TO_NUMBER(TO_CHAR(LAST_DAY(SYSDATE),'MMDD')) 
                             and A.CUSTOMER_CATEGORY =1
order by date_of_birth;


-- Check if no rows were inserted
v_rowcount := SQL%ROWCOUNT;

IF v_rowcount = 0 THEN
  -- No data found, insert placeholder record with today's date and flag = 0
  INSERT INTO CMP_CLIENTS_TBL_DOB ( FLAG , INSERT_DATE)
  VALUES ( 0 , TO_NUMBER ( TO_CHAR(SYSDATE,'YYYYMMDD') ));
END IF;

COMMIT;


  null;
end CMP_CLIENTS_PRO_DOB;
