# =============================================================================
# GitHub Linguist configuration
# Goal: project shows as JavaScript on GitHub (hide DDL, docs, raw templates)
# Docs: https://github.com/github-linguist/linguist/blob/main/docs/overrides.md
# =============================================================================

# --- Force JavaScript detection for the actual application source ----------
*.js  linguist-language=JavaScript
*.mjs linguist-language=JavaScript
*.cjs linguist-language=JavaScript

# --- Exclude data / doc / config file types from language stats ------------
*.md       linguist-detectable=false
*.txt      linguist-detectable=false
*.log      linguist-detectable=false
*.csv      linguist-detectable=false
*.sql      linguist-detectable=false
*.html     linguist-detectable=false
*.htm      linguist-detectable=false
*.xml      linguist-detectable=false
*.json     linguist-detectable=false
*.rtf      linguist-detectable=false
*.thmx     linguist-detectable=false
*.example  linguist-detectable=false
*.service  linguist-detectable=false
*.sh       linguist-detectable=false

# --- Mark non-source folders as generated/vendored (hidden from stats) -----
docs/**     linguist-documentation=true
logs/**     linguist-generated=true
data/**     linguist-generated=true
report/**   linguist-generated=true

# Legacy / DDL SQL scripts \u2014 not application source
db/**       linguist-vendored=true
sql/**      linguist-vendored=true
PRODUCTION_DATABASE_SETUP.sql linguist-vendored=true

# MS Word exported signature assets \u2014 not application source
src/templates/shared/signatures/**/raw/** linguist-vendored=true
